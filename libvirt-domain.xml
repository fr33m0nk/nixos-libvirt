<domain type="kvm">
  <name>nixos</name>
  <memory unit="GiB">8</memory>
  <vcpu>4</vcpu>
  <!-- firmware='efi' triggers libvirt's auto-selection of OVMF/AAVMF.
       Explicit <loader>/<nvram> paths are not needed — libvirt discovers
       the correct firmware from /usr/share/qemu/firmware/ descriptors.
       If your distro lacks firmware descriptors, uncomment and set the
       paths below for your distro:
         Fedora/Arch:  /usr/share/edk2/ovmf/OVMF_CODE.fd
         Debian/Ubuntu: /usr/share/OVMF/OVMF_CODE.fd
         NixOS:        /run/current-system/sw/share/OVMF/OVMF_CODE.fd  -->
  <os firmware="efi">
    <type arch="x86_64" machine="q35">hvm</type>
    <boot dev="hd"/>
  </os>
  <features>
    <acpi/>
    <apic/>
  </features>
  <cpu mode="host-passthrough"/>
  <devices>
    <disk type="file" device="disk">
      <driver name="qemu" type="qcow2"/>
      <source file="/var/lib/libvirt/images/nixos.qcow2"/>
      <target dev="vda" bus="virtio"/>
    </disk>
    <!-- Optional: cloud-init config drive for SSH keys / user-data.
         Generate with: genisoimage -output cloud-init.iso -volid cidata -joliet -rock user-data meta-data
         Then uncomment the block below.
    <disk type="file" device="cdrom">
      <source file="/var/lib/libvirt/images/cloud-init.iso"/>
      <target dev="sda" bus="sata"/>
      <readonly/>
    </disk>
    -->
    <interface type="network">
      <source network="default"/>
      <model type="virtio"/>
    </interface>
    <serial type="pty">
      <target port="0"/>
    </serial>
    <console type="pty">
      <target type="serial" port="0"/>
    </console>
    <channel type="unix">
      <source mode="bind"/>
      <target type="virtio" name="org.qemu.guest_agent.0"/>
    </channel>
    <graphics type="spice">
      <listen type="none"/>
    </graphics>
    <video>
      <model type="qxl"/>
    </video>
    <!-- virtio memory balloon: host can reclaim unused guest RAM -->
    <memballoon model="virtio">
      <stats period="10"/>
    </memballoon>
  </devices>
</domain>
